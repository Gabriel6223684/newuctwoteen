#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
require __DIR__ . '/../vendor/autoload.php';

use Dotenv\Dotenv;

$dotenv = Dotenv::createImmutable(__DIR__ . '/..');
$dotenv->load();

$app = new Application('Migrations');

$phinxBinary = __DIR__ . '/../vendor/bin/phinx';

$app->register('migrate')
    ->setCode(function () use ($phinxBinary) {
        passthru("$phinxBinary migrate");
    });

$app->register('rollback')
    ->setCode(function () use ($phinxBinary) {
        passthru("$phinxBinary rollback");
    });

$app->register('status')
    ->setCode(function () use ($phinxBinary) {
        passthru("$phinxBinary status");
    });

$app->run();
